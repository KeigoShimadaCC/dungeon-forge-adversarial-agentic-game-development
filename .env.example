# Optional credentials for real LLM harness runs (Phase 14B).
# Copy to .env locally if needed. Never commit .env or real keys.

# Primary API key (OpenAI-compatible providers)
DUNGEON_FORGE_LLM_API_KEY=

# Alternate name also accepted by the harness
# OPENAI_API_KEY=

# Optional override for OpenAI-compatible base URL
# DUNGEON_FORGE_LLM_BASE_URL=https://api.openai.com/v1

# Optional model name for player/reviewer completions
# DUNGEON_FORGE_LLM_MODEL=gpt-4o-mini
