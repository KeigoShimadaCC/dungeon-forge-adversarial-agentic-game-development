              "exit": true
            }
          ]
        },
        {
          "id": "path_hint",
          "text": "\"Stairs wait where the map breathes widest. Save your potions; the thieves and ghosts below show little mercy.\"",
          "choices": [
            {
              "id": "back_greeting",
              "label": "Ask something else",
              "nextNodeId": "greeting"
            },
            {
              "id": "thanks_path",
              "label": "Thank the keeper and go",
              "exit": true
            }
          ]
        }
      ]
