      "startNodeId": "greeting",
      "nodes": [
        {
          "id": "greeting",
          "text": "A hooded keeper studies a cracked shrine stone. \"Few reach the third floor with the bell still unclaimed.\"",
          "choices": [
            {
              "id": "ask_bell",
              "label": "Ask about the Dawn Bell",
              "nextNodeId": "bell_lore"
            },
            {
              "id": "ask_path",
