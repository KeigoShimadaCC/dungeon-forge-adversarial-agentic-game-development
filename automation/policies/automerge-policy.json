{
  "schemaVersion": 1,
  "enabled": true,
  "mergeMethod": "squash",
  "deleteBranchAfterMerge": true,
  "removeCleanWorktreeAfterMerge": true,
  "allowNoRemoteChecksWhenLocalGatePasses": true,
  "requiredLocalCommands": [
    "pnpm test",
    "pnpm run typecheck",
    "pnpm run lint",
    "pnpm run build",
    "git diff --check"
  ],
  "requiredPreflight": [
    "git status --short --branch",
    "agent --list-models includes composer-2.5",
    "active phase plan exists",
    "concept-and-ideas/01_NORTH_STAR_AND_VISION.md read",
    "concept-and-ideas/02_STRUCTURE_AND_TECH_SPECS.md read",
    "PROGRESS.MD read"
  ],
  "requiredArtifacts": [
    "codex plan result",
    "decision resolver result when questions were asked",
    "cursor implementation log",
    "cursor recheck log",
    "local validation result",
    "phase-plan completion checklist",
    "PR metadata",
    "merge metadata",
    "cleanup metadata"
  ],
  "blockMergeWhen": [
    "local validation fails",
    "remote PR checks fail",
    "phase acceptance criteria are incomplete",
    "cursor recheck reports blocking gaps",
    "forbidden MVP features are introduced",
    "GameEngine protocol is broken outside a phase that explicitly allows compatible protocol evolution",
    "gameplay requires API credentials",
    "reviewer output can mutate game state directly",
    "diff includes .env or credentials",
    "diff touches paths outside the phase allowedPaths list",
    "worktree has uncommitted changes after commit",
    "merge conflict cannot be resolved mechanically",
    "decision resolver returns block"
  ],
  "gapPolicy": {
    "blocking": "fix_before_merge_or_mark_blocked",
    "non_blocking": "append_to_PROGRESS_future_backlog_then_allow_merge_if_acceptance_passes",
    "out_of_scope": "append_to_PROGRESS_future_backlog_then_allow_merge"
  }
}
