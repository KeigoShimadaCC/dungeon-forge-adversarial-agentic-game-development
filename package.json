{
  "name": "dungeon-forge",
  "version": "0.0.0",
  "private": true,
  "description": "Local adversarial game-development testbed with deterministic text/ASCII game evidence",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "simulate-seed": "pnpm run build && node dist/src/harness/run-playthrough.js",
    "new-version": "pnpm run build && node dist/src/harness/new-version.js",
    "run-version": "pnpm run build && node dist/src/harness/run-version.js",
    "summarize-version": "pnpm run build && node dist/src/harness/summarize-version.js",
    "compare-versions": "pnpm run build && node dist/src/harness/compare-versions.js",
    "run-balance": "pnpm run build && node dist/src/harness/run-balance.js",
    "developer-task": "pnpm run build && node dist/src/harness/developer-task.js",
    "patch-proposal": "pnpm run build && node dist/src/harness/patch-proposal.js",
    "worktree-task": "pnpm run build && node dist/src/harness/worktree-agent.js",
    "loop-coordinator": "pnpm run build && node dist/src/harness/loop-coordinator-run.js",
    "accept-version": "pnpm run build && node dist/src/harness/accept-version.js",
    "demo-loop": "pnpm run build && node dist/src/harness/demo-loop-cli.js",
    "phase": "pnpm run build && node dist/src/harness/phase-runner-cli.js",
    "restricted-agent-dry-run": "pnpm run build && node dist/src/harness/restricted-agent/api-loop-cli.js",
    "restricted-agent-repair-loop": "pnpm run build && node dist/src/harness/restricted-agent/repair-loop-cli.js",
    "ci-smoke": "pnpm run build && node dist/src/harness/ci-smoke-cli.js",
    "verify-acceptance-evidence": "pnpm run build && node dist/src/harness/verify-acceptance-evidence-cli.js",
    "repo-checks": "pnpm run build && node dist/src/harness/repo-checks-cli.js",
    "human-play": "pnpm run build && node dist/src/human-play/human-play-cli.js",
    "browser-play": "pnpm run build && node dist/src/browser-play/browser-play-cli.js",
    "trace-replay": "pnpm run build && node dist/src/harness/trace-replay-cli.js",
    "version-dashboard": "pnpm run build && node dist/src/dashboard/version-dashboard-cli.js",
    "balance-analytics": "pnpm run build && node dist/src/harness/balance-analytics-cli.js",
    "longitudinal-benchmark": "pnpm run build && node dist/src/harness/longitudinal-benchmark-cli.js",
    "export-static-demo": "pnpm run build && node dist/src/static-demo/static-demo-export-cli.js",
    "control-room-web-shell": "pnpm run build && node dist/src/control-room/web-shell/control-room-web-shell-cli.js",
    "content-governance": "pnpm run build && node dist/src/harness/content-governance-cli.js",
    "optional-media": "pnpm run build && node dist/src/harness/optional-media-cli.js",
    "check": "pnpm test && pnpm run typecheck && pnpm run lint && pnpm run build && pnpm run ci-smoke && pnpm run verify-acceptance-evidence"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.29",
    "eslint": "^9.28.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^3.2.1"
  }
}
