{
  "name": "dungeon-forge",
  "version": "0.0.0",
  "private": true,
  "description": "Agentic adversarial game-development testbed (Phase 01A scaffold)",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "simulate-seed": "pnpm run build && node dist/src/harness/run-playthrough.js",
    "new-version": "pnpm run build && node dist/src/harness/new-version.js",
    "run-version": "pnpm run build && node dist/src/harness/run-version.js",
    "summarize-version": "pnpm run build && node dist/src/harness/summarize-version.js",
    "compare-versions": "pnpm run build && node dist/src/harness/compare-versions.js",
    "run-balance": "pnpm run build && node dist/src/harness/run-balance.js",
    "developer-task": "pnpm run build && node dist/src/harness/developer-task.js",
    "accept-version": "pnpm run build && node dist/src/harness/accept-version.js",
    "demo-loop": "pnpm run build && node dist/src/harness/demo-loop-cli.js",
    "phase": "pnpm run build && node dist/src/harness/phase-runner-cli.js",
    "ci-smoke": "pnpm run build && node dist/src/harness/ci-smoke-cli.js",
    "verify-acceptance-evidence": "pnpm run build && node dist/src/harness/verify-acceptance-evidence-cli.js",
    "repo-checks": "pnpm run build && node dist/src/harness/repo-checks-cli.js",
    "check": "pnpm test && pnpm run typecheck && pnpm run lint && pnpm run build && pnpm run ci-smoke && pnpm run verify-acceptance-evidence"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.29",
    "eslint": "^9.28.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^3.2.1"
  }
}
